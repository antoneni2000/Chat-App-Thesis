@startuml Authentication_Activity_Diagram
title Diagrama de Activitate - Modalitati de Autentificare

skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam ActivityBorderColor #2C3E50
skinparam ActivityDiamondBackgroundColor #FFF4E0
skinparam ActivityDiamondBorderColor #B8860B
skinparam ArrowColor #2C3E50
skinparam PartitionBorderColor #34495E
skinparam PartitionFontStyle bold

|#D4EFDF|Utilizator|
start
:Acceseaza pagina /login;

|#D6EAF8|Frontend|
:Randeaza LoginPage\n(formular + buton Google);

|#D4EFDF|Utilizator|
if (Are cont?) then (Nu)
  :Apasa "Inregistrare";

  |#D6EAF8|Frontend|
  :Navigheaza la /register;
  :Randeaza RegisterPage;

  |#D4EFDF|Utilizator|
  if (Metoda inregistrare?) then (Email + Parola)
    :Completeaza\nusername, email,\nparola, displayName;
    :Submit formular;

    |#D6EAF8|Frontend|
    :Valideaza local\n(camp gol, format email);
    :POST /api/auth/register\n{ username, email, password, displayName };

    |#E8DAEF|Backend|
    :@Valid RegisterRequest;
    :countMetCriteria(password)\n(>=6 char, upper, lower, digit, special);
    if (Criterii >= 3 din 5?) then (Nu)
      #FADBD8:Return 400\n"Parola prea slaba";
      |#D6EAF8|Frontend|
      :Afiseaza eroare;
      stop
    else (Da)
    endif

    |#FADBD8|Baza de Date|
    :SELECT COUNT(*) FROM users WHERE email = ?;

    |#E8DAEF|Backend|
    if (Email existent?) then (Da)
      #FADBD8:Return 400\n"Email already registered";
      stop
    else (Nu)
    endif

    |#FADBD8|Baza de Date|
    :SELECT COUNT(*) FROM users WHERE username = ?;

    |#E8DAEF|Backend|
    if (Username existent?) then (Da)
      #FADBD8:Return 400\n"Username already taken";
      stop
    else (Nu)
    endif

    :passwordEncoder.encode(password)\n(BCrypt);
    :Build User entity;

    |#FADBD8|Baza de Date|
    :INSERT INTO users\n(username, email, passwordHash,\ndisplayName);

    |#E8DAEF|Backend|
    :User.id generat;

  else (Google OAuth)
    :Apasa "Sign in with Google";

    |#FCF3CF|Google (GIS)|
    :Deschide popup\nselector cont;

    |#D4EFDF|Utilizator|
    :Selecteaza cont Google;
    :Acorda consimtamant;

    |#FCF3CF|Google (GIS)|
    :Autentifica user pe\nserverele Google;
    :Genereaza ID Token JWT\n(semnat RS256);
    :Callback frontend cu idToken;

    |#D6EAF8|Frontend|
    :POST /api/auth/google\n{ idToken };

    |#E8DAEF|Backend|
    if (app.google.client-id\nconfigurat?) then (Nu)
      #FADBD8:Return 500\n"Not configured";
      stop
    else (Da)
    endif
    :GoogleIdTokenVerifier\n.setAudience(clientId).build();
    :verifier.verify(idToken);
    if (Token valid?) then (Nu)
      #FADBD8:Return 401\n"Invalid Google token";
      stop
    else (Da)
    endif
    :Extrage payload:\nemail, emailVerified,\nname, picture;
    if (emailVerified == true?) then (Nu)
      #FADBD8:Return 401\n"Email not verified";
      stop
    else (Da)
    endif

    |#FADBD8|Baza de Date|
    :SELECT * FROM users WHERE email = ?;

    |#E8DAEF|Backend|
    note right: User nu exista (inregistrare noua)
    :Genereaza username unic\ndin prefixul email-ului\n(adauga sufix daca exista);
    :Build User\n(passwordHash = NULL,\navatarUrl = picture);

    |#FADBD8|Baza de Date|
    :INSERT INTO users;
  endif

else (Da)
  :Apasa "Login";

  |#D6EAF8|Frontend|
  :Ramane pe /login;

  |#D4EFDF|Utilizator|
  if (Metoda login?) then (Email/Username + Parola)
    :Completeaza\nidentifier + parola;
    :Submit formular;

    |#D6EAF8|Frontend|
    :POST /api/auth/login\n{ identifier, password };

    |#E8DAEF|Backend|
    :@Valid LoginRequest;

    |#FADBD8|Baza de Date|
    :SELECT * FROM users\nWHERE email = ? OR username = ?;

    |#E8DAEF|Backend|
    if (User gasit?) then (Nu)
      #FADBD8:Return 401\n"Credentiale incorecte";
      stop
    else (Da)
    endif
    :authenticationManager.authenticate(\n UsernamePasswordAuthenticationToken);
    :BCrypt.matches(input, passwordHash);
    if (Parola corecta?) then (Nu)
      #FADBD8:Return 401\n"Credentiale incorecte";
      stop
    else (Da)
    endif

  else (Google OAuth)
    :Apasa "Sign in with Google";

    |#FCF3CF|Google (GIS)|
    :Popup selector cont;

    |#D4EFDF|Utilizator|
    :Selecteaza contul;

    |#FCF3CF|Google (GIS)|
    :Emite ID Token JWT;

    |#D6EAF8|Frontend|
    :POST /api/auth/google\n{ idToken };

    |#E8DAEF|Backend|
    :Verifica token\n(GoogleIdTokenVerifier);
    if (Token valid si\nemail verificat?) then (Nu)
      #FADBD8:Return 401;
      stop
    else (Da)
    endif

    |#FADBD8|Baza de Date|
    :SELECT * FROM users WHERE email = ?;

    |#E8DAEF|Backend|
    note right: User existent
    if (avatarUrl NULL si\nGoogle are picture?) then (Da)
      |#FADBD8|Baza de Date|
      :UPDATE users\nSET avatar_url = picture;
      |#E8DAEF|Backend|
    else (Nu)
    endif
  endif
endif

|#E8DAEF|Backend|
#D5F5E3:jwtUtil.generateToken(email)\n(HS384, exp = 24h);
#D5F5E3:Return 200 - AuthResponse\n{ token, userId, username,\nemail, displayName, avatarUrl };

|#D6EAF8|Frontend|
:localStorage.setItem("token", JWT);
:AuthContext.setUser(user)\nisAuthenticated = true;
:navigate("/chat");

|#D4EFDF|Utilizator|
:Utilizator autentificat pe /chat;
stop

@enduml
