@startuml Chat_App_Complete_Architecture

!theme plain
top to bottom direction
skinparam linetype ortho
skinparam packageStyle folder
skinparam defaultFontSize 10

' ================================================
' LAYER 1: CONTROLLERS (Horizontal inside package)
' ================================================

package "CONTROLLERS" {
    class AuthController
    class ChatController
    class ChatWebSocketController
    class FileController
    class MessageSearchController
    class UserController
    class UserStatusController
}

AuthController -[hidden]right- ChatController
ChatController -[hidden]right- ChatWebSocketController
ChatWebSocketController -[hidden]right- FileController
FileController -[hidden]right- MessageSearchController
MessageSearchController -[hidden]right- UserController
UserController -[hidden]right- UserStatusController

' ================================================
' LAYER 2: SERVICES (Horizontal inside package)
' ================================================

package "SERVICES" {
    class ChatService
    class FileStorageService
    class MessageSearchService
    class MessageCleanupService
    class UserStatusService
}

ChatService -[hidden]right- FileStorageService
FileStorageService -[hidden]right- MessageSearchService
MessageSearchService -[hidden]right- MessageCleanupService
MessageCleanupService -[hidden]right- UserStatusService

' ================================================
' LAYER 3: REPOSITORIES (Horizontal inside package)
' ================================================

package "REPOSITORIES" {
    interface UserRepository << interface >>
    interface ChatRepository << interface >>
    interface ChatMemberRepository << interface >>
    interface MessageRepository << interface >>
    interface UserStatusRepository << interface >>
}

UserRepository -[hidden]right- ChatRepository
ChatRepository -[hidden]right- ChatMemberRepository
ChatMemberRepository -[hidden]right- MessageRepository
MessageRepository -[hidden]right- UserStatusRepository

' ================================================
' LAYER 4: ENTITIES (Horizontal inside package)
' ================================================

package "ENTITIES (JPA)" {
    class User
    class Chat
    class ChatMember
    class Message
    class UserStatus
}

User -[hidden]right- Chat
Chat -[hidden]right- ChatMember
ChatMember -[hidden]right- Message
Message -[hidden]right- UserStatus

' ================================================
' LAYER 5: SECURITY (Right side - Vertical)
' ================================================

package "SECURITY" {
    class JwtUtil
    class JwtAuthFilter
    class WebSocketAuthInterceptor
    class SecurityConfig
    class SecurityUtils
    class CustomUserDetailsService
    class PresenceListener
}

JwtUtil --> JwtAuthFilter
JwtAuthFilter --> WebSocketAuthInterceptor
WebSocketAuthInterceptor --> SecurityConfig
SecurityConfig --> SecurityUtils
SecurityUtils --> CustomUserDetailsService
CustomUserDetailsService --> PresenceListener

' ================================================
' CONTROLLERS TO SERVICES (Vertical flow)
' ================================================

AuthController --> ChatService
ChatController --> ChatService
ChatWebSocketController --> ChatService
FileController --> FileStorageService
MessageSearchController --> MessageSearchService
UserController --> ChatService
UserStatusController --> UserStatusService

' ================================================
' SERVICES TO REPOSITORIES (Vertical flow)
' ================================================

ChatService --> ChatRepository
ChatService --> ChatMemberRepository
ChatService --> MessageRepository
ChatService --> UserRepository

MessageSearchService --> MessageRepository

UserStatusService --> UserStatusRepository

MessageCleanupService --> MessageRepository
MessageCleanupService --> FileStorageService

' ================================================
' REPOSITORIES TO ENTITIES (Vertical flow)
' ================================================

UserRepository --> User
ChatRepository --> Chat
ChatMemberRepository --> ChatMember
MessageRepository --> Message
UserStatusRepository --> UserStatus

' ================================================
' SECURITY CONNECTIONS
' ================================================

AuthController -.-> JwtUtil
ChatWebSocketController -.-> WebSocketAuthInterceptor
ChatController -.-> SecurityUtils
UserController -.-> SecurityUtils
FileController -.-> SecurityUtils

@enduml
