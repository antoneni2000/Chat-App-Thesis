# ================================================================
# Template variabile de mediu — copiaza in .env si completeaza
# ================================================================

DB_URL=jdbc:postgresql://localhost:5432/chatapp
DB_USERNAME=postgres
DB_PASSWORD=your_password_here

GCS_PROJECT_ID=your-gcp-project-id
GCS_BUCKET=your-bucket-name
GCS_CREDENTIALS_PATH=/absolute/path/to/gcs-credentials.json
GCS_SIGNED_URL_EXPIRY_DAYS=7

GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Genereaza cu: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=generate-a-random-64-byte-hex-string-here
JWT_EXPIRATION_MS=86400000

JPA_SHOW_SQL=false
LOG_LEVEL_SECURITY=WARN
LOG_LEVEL_APP=INFO

CLEANUP_RETENTION_DAYS=30
